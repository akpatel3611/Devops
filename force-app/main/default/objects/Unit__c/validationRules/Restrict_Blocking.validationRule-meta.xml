<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Restrict_Blocking</fullName>
    <active>false</active>
    <errorConditionFormula>AND( ISPICKVAL(Status__c, &quot;Blocked&quot;), ISPICKVAL(PRIORVALUE(Status__c), &quot;Booked&quot;) )</errorConditionFormula>
    <errorMessage>Cannot Block a Booked Unit</errorMessage>
</ValidationRule>
